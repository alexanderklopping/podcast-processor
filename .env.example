# Required: API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for pushing feeds to GitHub Pages
# GITHUB_TOKEN=ghp_...
# FEEDS_GITHUB_TOKEN=ghp_...    # Alternative name (used in GitHub Actions)

# Optional: yt-dlp configuration for YouTube/video downloads
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FILE=cookies.txt
# YTDLP_IMPERSONATE=chrome
# YTDLP_REMOTE_COMPONENTS=

# Optional: Cloud mode (auto-detected on Render, set manually elsewhere)
# IS_CLOUD=true

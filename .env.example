# Required: API keys
GROQ_API_KEY=gsk_...                    # For transcription (default, ~89% cheaper than OpenAI)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Use OpenAI Whisper instead of Groq for transcription
# TRANSCRIPTION_PROVIDER=openai         # Default: "groq"
# OPENAI_API_KEY=sk-...                 # Required only if TRANSCRIPTION_PROVIDER=openai

# Optional: GitHub token for pushing feeds to GitHub Pages
# GITHUB_TOKEN=ghp_...
# FEEDS_GITHUB_TOKEN=ghp_...    # Alternative name (used in GitHub Actions)

# Optional: yt-dlp configuration for YouTube/video downloads
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FILE=cookies.txt
# YTDLP_IMPERSONATE=chrome
# YTDLP_REMOTE_COMPONENTS=

# Optional: Cloud mode (auto-detected on Render, set manually elsewhere)
# IS_CLOUD=true

# Optional: Long-lived worker mode for Render-style deploys
# PROCESS_INTERVAL_SECONDS=3600
